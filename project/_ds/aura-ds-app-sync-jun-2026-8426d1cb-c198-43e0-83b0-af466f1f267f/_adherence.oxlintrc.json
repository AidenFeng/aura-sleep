{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/general/Body/**",
              "components/general/Button/**",
              "components/general/Caption/**",
              "components/general/Card/**",
              "components/general/Choice/**",
              "components/general/GlassTile/**",
              "components/general/Label/**",
              "components/general/Pill/**",
              "components/general/PremiumTag/**",
              "components/general/Screen/**",
              "components/general/SectionLabel/**",
              "components/general/SegmentControl/**",
              "components/general/Title/**",
              "components/general/Toggle/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='Body'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|dim|serif|variant|style|key|ref|className|style|children)$/]",
        "message": "<Body> doesn't accept that prop. Declared props: children, dim, serif, variant, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Body'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:hero|title|headline|bodyLg|body|label|caption)$/]",
        "message": "<Body> variant must be one of 'hero' | 'title' | 'headline' | 'bodyLg' | 'body' | 'label' | 'caption'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|variant|icon|disabled|onPress|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: label, variant, icon, disabled, onPress, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|ghost|line)$/]",
        "message": "<Button> variant must be one of 'solid' | 'ghost' | 'line'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Caption'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|dim|style|key|ref|className|style|children)$/]",
        "message": "<Caption> doesn't accept that prop. Declared props: children, dim, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|highlight|flat|radius|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, highlight, flat, radius, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Choice'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|values|onPick|onToggle|options|multi|wrap|flat|key|ref|className|style|children)$/]",
        "message": "<Choice> doesn't accept that prop. Declared props: value, values, onPick, onToggle, options, multi, wrap, flat."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<GlassTile> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Label'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|dim|style|key|ref|className|style|children)$/]",
        "message": "<Label> doesn't accept that prop. Declared props: children, dim, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|on|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: label, on."
      },
      {
        "selector": "JSXOpeningElement[name.name='PremiumTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|key|ref|className|style|children)$/]",
        "message": "<PremiumTag> doesn't accept that prop. Declared props: label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Screen'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|safeTop|plain|key|ref|className|style|children)$/]",
        "message": "<Screen> doesn't accept that prop. Declared props: children, safeTop, plain."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionLabel'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<SectionLabel> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentControl'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|active|onPick|key|ref|className|style|children)$/]",
        "message": "<SegmentControl> doesn't accept that prop. Declared props: options, active, onPick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Title'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<Title> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:on|onPress|label|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: on, onPress, label."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
